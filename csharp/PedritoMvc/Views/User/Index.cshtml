@{
    ViewData["Title"] = "Usuarios";
}
@model IEnumerable<PedritoMvc.Models.User>

<h1 class="mb-4">Lista de Usuarios</h1>

<p>
    <a asp-controller="User" asp-action="Create" class="btn btn-primary">Nuevo Usuario</a>
</p>


<table class="table table-bordered table-striped">
    <thead class="table-dark">
    <tr>
        <th>Id</th>
        <th>Nombre</th>
        <th>Correo</th>
        <th>Edad</th>
        <th>Acciones</th>
    </tr>
    </thead>
    <tbody>

    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Id</td>
            <td>@user.Names</td>
            <td>@user.Lastnames</td>
            <td>@user.Email</td>
            <td>
                <a asp-controller="User" asp-action="Details" class="btn btn-info btn-sm">Detalles</a>
                <a asp-controller="User" asp-action="Edit" class="btn btn-warning btn-sm">Editar</a>
                <a asp-controller="User" asp-action="Delete" class="btn btn-danger btn-sm">Eliminar</a>
            </td>
        </tr>   
    }
    </tbody>
</table>